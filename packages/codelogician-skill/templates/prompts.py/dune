(rule
 (mode
  (promote (until-clean)))
 (deps
  (:templ prompts.py.jinja)
  (:context %{project_root}/../knowledge-base/context/context.yaml))
 (target prompts.py)
 (action
  (progn
   (run jinja -d %{context} -o %{target} %{templ})
   (run uvx ty check %{target})
   (run uvx ruff format %{target}))))
