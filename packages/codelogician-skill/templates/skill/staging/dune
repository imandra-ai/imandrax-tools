; Top-level staging rules:
;   - copy plain .md files from ../src/
;   - render iml-language-guide.md from iml-language-guide.md.jinja
;   - assemble SKILL.md from SKILL.pt1.md1 + janet-generated tree

(copy_files
 (alias skill)
 (mode
  (promote (until-clean)))
 (files ../src/*.md))

(rule
 (alias skill)
 (mode
  (promote (until-clean)))
 (deps
  (:tpl ../src/iml-language-guide.md.jinja)
  (:ctx %{project_root}/../knowledge-base/context/context.yaml))
 (target iml-language-guide.md)
 (action
  (bash "jinja -d %{ctx} -o %{target} %{tpl}")))

(rule
 (alias skill)
 (mode
  (promote (until-clean)))
 (deps
  (:pt1 ../src/SKILL.pt1.md1)
  (source_tree ../src)
  ../../../scripts/skill-dir-tree.janet)
 (target SKILL.md)
 (action
  (with-stdout-to
   %{target}
   (progn
    (cat %{pt1})
    (echo "\n")
    (bash "janet ../../../scripts/skill-dir-tree.janet ../src")
    (echo
     "\nNote: there are some *.iml examples and *.json files as well that are not shown in the tree. Find them yourself if needed.")))))
