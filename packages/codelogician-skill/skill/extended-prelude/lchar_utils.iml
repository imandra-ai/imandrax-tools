  | LChar.Char (true,  true,  true,  true,  true,  false, false, true)  -> "\xF9"
  | LChar.Char (true,  true,  true,  true,  true,  false, true,  false) -> "\xFA"
  | LChar.Char (true,  true,  true,  true,  true,  false, true,  true)  -> "\xFB"
  | LChar.Char (true,  true,  true,  true,  true,  true,  false, false) -> "\xFC"
  | LChar.Char (true,  true,  true,  true,  true,  true,  false, true)  -> "\xFD"
  | LChar.Char (true,  true,  true,  true,  true,  true,  true,  false) -> "\xFE"
  | LChar.Char (true,  true,  true,  true,  true,  true,  true,  true)  -> "\xFF"

(* Convert an LString.t to a native string by concatenating single-char strings *)
let rec string_of_lstring (s : LString.t) : string =
  match s with
  | [] -> ""
  | c :: rest -> String.append (string_of_lchar c) (string_of_lstring rest)