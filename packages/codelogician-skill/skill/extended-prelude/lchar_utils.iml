(* Reverse mapping: LChar.t → single-character native string *)
let string_of_lchar (c : LChar.t) : string =
  match c with
  (* Control characters 0-31 *)
  | LChar.Char (false, false, false, false, false, false, false, false) -> "\000"
  | LChar.Char (false, false, false, false, false, false, false, true)  -> "\001"
  | LChar.Char (false, false, false, false, false, false, true,  false) -> "\002"
  | LChar.Char (false, false, false, false, false, false, true,  true)  -> "\003"
  | LChar.Char (false, false, false, false, false, true,  false, false) -> "\004"
  | LChar.Char (false, false, false, false, false, true,  false, true)  -> "\005"
  | LChar.Char (false, false, false, false, false, true,  true,  false) -> "\006"
