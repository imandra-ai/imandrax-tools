let lchar_of_string_opt (s : string) : LChar.t option =
  match s with
  (* Control characters 0-31 *)
  | "\000" -> Some Char_table.nul
  | "\001" -> Some Char_table.soh
  | "\002" -> Some Char_table.stx
  | "\003" -> Some Char_table.etx
  | "\004" -> Some Char_table.eot
  | "\005" -> Some Char_table.enq
  | "\006" -> Some Char_table.ack
  | "\007" -> Some Char_table.bel
  | "\008" -> Some Char_table.bs
  | "\t"   -> Some Char_table.ht
  | "\n"   -> Some Char_table.lf
  | "\011" -> Some Char_table.vt
  | "\012" -> Some Char_table.ff
  | "\r"   -> Some Char_table.cr
  | "\014" -> Some Char_table.so
  | "\015" -> Some Char_table.si
  | "\016" -> Some Char_table.dle
  | "\017" -> Some Char_table.dc1
  | "\018" -> Some Char_table.dc2
  | "\019" -> Some Char_table.dc3
  | "\020" -> Some Char_table.dc4
  | "\021" -> Some Char_table.nak
  | "\022" -> Some Char_table.syn
  | "\023" -> Some Char_table.etb
  | "\024" -> Some Char_table.can
  | "\025" -> Some Char_table.em
  | "\026" -> Some Char_table.sub
  | "\027" -> Some Char_table.esc
  | "\028" -> Some Char_table.fs
  | "\029" -> Some Char_table.gs
  | "\030" -> Some Char_table.rs
  | "\031" -> Some Char_table.us
  (* Printable characters 32-47 *)
  | " "  -> Some Char_table.space
  | "!"  -> Some Char_table.exclaim
  | "\"" -> Some Char_table.dquote
  | "#"  -> Some Char_table.hash
  | "$"  -> Some Char_table.dollar
  | "%"  -> Some Char_table.percent
  | "&"  -> Some Char_table.ampersand
  | "'"  -> Some Char_table.squote
  | "("  -> Some Char_table.lparen
  | ")"  -> Some Char_table.rparen
  | "*"  -> Some Char_table.star
  | "+"  -> Some Char_table.plus
  | ","  -> Some Char_table.comma
  | "-"  -> Some Char_table.minus
  | "."  -> Some Char_table.dot
  | "/"  -> Some Char_table.slash
  (* Digits 48-57 *)
  | "0"  -> Some Char_table.digit_0
  | "1"  -> Some Char_table.digit_1
  | "2"  -> Some Char_table.digit_2
  | "3"  -> Some Char_table.digit_3
  | "4"  -> Some Char_table.digit_4
  | "5"  -> Some Char_table.digit_5
  | "6"  -> Some Char_table.digit_6
  | "7"  -> Some Char_table.digit_7
  | "8"  -> Some Char_table.digit_8
  | "9"  -> Some Char_table.digit_9
  (* Punctuation 58-64 *)
  | ":"  -> Some Char_table.colon
  | ";"  -> Some Char_table.semicolon
  | "<"  -> Some Char_table.lt
  | "="  -> Some Char_table.eq
  | ">"  -> Some Char_table.gt
  | "?"  -> Some Char_table.question
  | "@"  -> Some Char_table.at
  (* Uppercase letters 65-90 *)
  | "A"  -> Some Char_table.upper_a
  | "B"  -> Some Char_table.upper_b
  | "C"  -> Some Char_table.upper_c
  | "D"  -> Some Char_table.upper_d
  | "E"  -> Some Char_table.upper_e
  | "F"  -> Some Char_table.upper_f
  | "G"  -> Some Char_table.upper_g
  | "H"  -> Some Char_table.upper_h
  | "I"  -> Some Char_table.upper_i
  | "J"  -> Some Char_table.upper_j
  | "K"  -> Some Char_table.upper_k
  | "L"  -> Some Char_table.upper_l
  | "M"  -> Some Char_table.upper_m
  | "N"  -> Some Char_table.upper_n
  | "O"  -> Some Char_table.upper_o
  | "P"  -> Some Char_table.upper_p
  | "Q"  -> Some Char_table.upper_q
  | "R"  -> Some Char_table.upper_r
  | "S"  -> Some Char_table.upper_s
  | "T"  -> Some Char_table.upper_t
  | "U"  -> Some Char_table.upper_u
  | "V"  -> Some Char_table.upper_v
  | "W"  -> Some Char_table.upper_w
  | "X"  -> Some Char_table.upper_x
  | "Y"  -> Some Char_table.upper_y
  | "Z"  -> Some Char_table.upper_z
  (* Punctuation 91-96 *)
  | "["  -> Some Char_table.lbracket
  | "\\" -> Some Char_table.backslash
  | "]"  -> Some Char_table.rbracket
  | "^"  -> Some Char_table.caret
  | "_"  -> Some Char_table.underscore
  | "`"  -> Some Char_table.backtick
  (* Lowercase letters 97-122 *)
  | "a"  -> Some Char_table.lower_a
  | "b"  -> Some Char_table.lower_b
  | "c"  -> Some Char_table.lower_c
  | "d"  -> Some Char_table.lower_d
  | "e"  -> Some Char_table.lower_e
  | "f"  -> Some Char_table.lower_f
  | "g"  -> Some Char_table.lower_g
  | "h"  -> Some Char_table.lower_h
  | "i"  -> Some Char_table.lower_i
  | "j"  -> Some Char_table.lower_j
  | "k"  -> Some Char_table.lower_k
  | "l"  -> Some Char_table.lower_l
  | "m"  -> Some Char_table.lower_m
  | "n"  -> Some Char_table.lower_n
  | "o"  -> Some Char_table.lower_o
  | "p"  -> Some Char_table.lower_p
  | "q"  -> Some Char_table.lower_q
  | "r"  -> Some Char_table.lower_r
  | "s"  -> Some Char_table.lower_s
  | "t"  -> Some Char_table.lower_t
  | "u"  -> Some Char_table.lower_u
  | "v"  -> Some Char_table.lower_v
  | "w"  -> Some Char_table.lower_w
  | "x"  -> Some Char_table.lower_x
  | "y"  -> Some Char_table.lower_y
  | "z"  -> Some Char_table.lower_z
  (* Punctuation 123-126 *)
  | "{"  -> Some Char_table.lbrace
  | "|"  -> Some Char_table.pipe
  | "}"  -> Some Char_table.rbrace
  | "~"  -> Some Char_table.tilde
  (* DEL 127 *)
  | "\127" -> Some Char_table.del
  (* High bytes 128-255 *)
  | "\x80" -> Some Char_table.x80
  | "\x81" -> Some Char_table.x81
  | "\x82" -> Some Char_table.x82
  | "\x83" -> Some Char_table.x83
  | "\x84" -> Some Char_table.x84
  | "\x85" -> Some Char_table.x85
  | "\x86" -> Some Char_table.x86
  | "\x87" -> Some Char_table.x87
  | "\x88" -> Some Char_table.x88
  | "\x89" -> Some Char_table.x89
  | "\x8A" -> Some Char_table.x8a
  | "\x8B" -> Some Char_table.x8b
  | "\x8C" -> Some Char_table.x8c
  | "\x8D" -> Some Char_table.x8d
  | "\x8E" -> Some Char_table.x8e
  | "\x8F" -> Some Char_table.x8f
  | "\x90" -> Some Char_table.x90
  | "\x91" -> Some Char_table.x91
