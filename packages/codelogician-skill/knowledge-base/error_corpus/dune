(rule
  (mode (promote (until-clean)))
  (target schema.json)
  (deps src/error_corpus/schema.py)
  (action
    (with-stdout-to %{target}
      (run uv run %{deps})))
)

(rule
  (mode (promote (until-clean)))
  (target error_corpus.yaml)
  (deps
    (source_tree data)
    (source_tree src)
    pyproject.toml
    uv.lock
    README.md
    scripts/join_data_yaml.py
    (:schema schema.json))
  (action
    (with-stdout-to %{target}
      (progn
        (echo "# yaml-language-server: $schema=./%{schema}\n")
        (run uv run scripts/join_data_yaml.py)
      )
    )
  )
)
