(rule
  (mode (promote (until-clean)))
  (target error_corpus_schema.json)
  (deps src/error_corpus/schema.py)
  (action
    (with-stdout-to %{target}
      (run uv run %{deps})))
)

(rule
  (mode (promote (until-clean)))
  (target error_corpus.json)
  (deps
    (source_tree data)
    (:schema error_corpus_schema.json))
  (action
    (with-stdout-to %{target}
      (bash "yq ea -o=json '[.]' data/*/data.yaml | yq -o=json '{\"$schema\": \"./%{schema}\", \"items\": flatten}'")))
)

(rule
  (mode (promote (until-clean)))
  (target error_corpus.yaml)
  (deps
    (source_tree data)
    (source_tree src)
    (source_tree .venv)  ; no needed. but it makes build faster
    pyproject.toml
    uv.lock
    README.md
    scripts/join_data_yaml.py)
  (action
    (with-stdout-to %{target}
      (run uv run scripts/join_data_yaml.py)
    )
  )
)
