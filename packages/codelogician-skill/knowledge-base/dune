; Combine all sub-artifacts -> context.yaml, promoted to source tree
(rule
 (mode (promote (until-clean)))
 (targets context.yaml)
 (deps
  constants/constants.yaml
  extraction_tactic_docs_from_iml_prelude/tactics.yaml)
 (action
  (with-stdout-to
   %{targets}
   (bash "yq eval-all '. as $item ireduce ({}; . * $item)' %{deps}"))))
