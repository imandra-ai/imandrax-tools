 (rule
  (mode
   (promote (until-clean)))
  (deps
   (:in repro.iml))
  (target eval_res.json)
  (action
   (with-stdout-to
    %{target}
    (run iml-eval-corpus-imx-eval %{in}))))

    (rule
       (alias runtest)
       (mode
        (promote (until-clean)))
       (deps
        (:in repro.iml))
       (action
        (run
         sh
         -c
         "iml-eval-corpus-imx-eval %{in} | jq -e '.eval_res.errors | length >= 0'")))
    )

