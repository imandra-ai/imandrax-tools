; Build skill/ from templates/skill/staging/ by rsyncing without dune files.
;
; Layout:
;   templates/skill/src/      sources (md, md.jinja, iml, SKILL.pt1.md1)
;   templates/skill/staging/  dune files + promoted build outputs
;   skill/                    final distribution (staging minus dune files)

(alias
 (name default)
 (deps
  (alias skill)))

(rule
 (alias skill)
 (mode
  (promote (until-clean)))
 (deps
  (alias_rec templates/skill/staging/skill)
  (source_tree templates/skill/staging))
 (target
  (dir skill))
 (action
  (bash "rsync -a --delete --exclude=dune templates/skill/staging/ skill/")))
