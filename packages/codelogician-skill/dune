; Build the skill/ directory from sources:
;
;   templates/skill/   — main content (*.md, *.iml, *.md.jinja)
;   extended-prelude/  — additional IML prelude files
;   knowledge-base/    — context.yaml for jinja rendering
;
; All rules use `(alias skill)` and `(promote (until-clean))` so that
; `dune build @skill` regenerates skill/ in the source tree.
;
; Source layout → skill/ mapping:
;   templates/skill/**/*.md          → skill/**/*.md        (copy)
;   templates/skill/**/*.iml         → skill/**/*.iml       (copy)
;   templates/skill/**/*.md.jinja    → skill/**/*.md        (render via jinja)
;   templates/skill/SKILL.md1        → skill/SKILL.md       (copy + janet post-processing)
;   extended-prelude/*.iml           → skill/extended-prelude/*.iml (copy)

; 1. Copy extended-prelude .iml files into skill/extended-prelude/
(subdir skill/extended-prelude
  (copy_files
    (alias skill)
    (mode (promote (until-clean)))
    (files ../../extended-prelude/*.iml)))

; 2. Copy .md and .iml files from templates/skill/ preserving directory structure.
;    Excludes SKILL.md1 which is handled separately below.
(rule
 (alias skill)
 (mode (promote (until-clean)))
 (deps
  (glob_files_rec templates/skill/**.md)
  (glob_files_rec templates/skill/**.iml))
 (action
  (bash "\
    cd templates/skill && find . -type f \\( -name '*.md' -o -name '*.iml' \\) ! -name 'SKILL.md1' | while read -r f; do \
      mkdir -p \"../../skill/$(dirname \"$f\")\" && \
      cp \"$f\" \"../../skill/$f\"; \
    done")))

; 3. Render .jinja templates with context.yaml, stripping the .jinja extension.
;    e.g. templates/skill/reference/tactics.md.jinja → skill/reference/tactics.md
(rule
 (alias skill)
 (mode (promote (until-clean)))
 (deps
  (glob_files_rec templates/skill/**.jinja)
  knowledge-base/context.yaml)
 (action
  (bash "\
    cd templates/skill && find . -name '*.jinja' | while read -r f; do \
      dest=\"../../skill/${f%.jinja}\"; \
      mkdir -p \"$(dirname \"$dest\")\" && \
      jinja -d ../../knowledge-base/context.yaml -o \"$dest\" \"$f\"; \
    done")))

; 4. Generate SKILL.md: copy the template then run janet to insert a directory
;    tree listing all skill/ content files with their frontmatter descriptions.
;    The janet script scans templates/skill/ (not skill/) for referential
;    transparency — it derives final filenames by stripping .jinja extensions.
(subdir skill
 (rule
  (alias skill)
  (mode (promote (until-clean)))
  (deps
   (glob_files_rec ../templates/skill/**.md)
   (glob_files_rec ../templates/skill/**.iml)
   (glob_files_rec ../templates/skill/**.jinja)
   (:skill-in ../templates/skill/SKILL.md1)
   ../scripts/update-skill-reference.janet)
  (target SKILL.md)
  (action
   (bash "\
     cp %{skill-in} %{target} && \
     chmod u+w %{target} && \
     janet ../scripts/update-skill-reference.janet ../templates/skill %{target}"))))
