; Build the skill/:
; ====================
;
; All rules use `(alias skill)` and `(promote (until-clean))` so that
; `dune build @skill` regenerates skill/ in the source tree.
;
; Source layout → skill/ mapping:
;   templates/skill/**/*.md          → skill/**/*.md        (copy)
;   templates/skill/**/*.iml         → skill/**/*.iml       (copy)
;   templates/skill/**/*.md.jinja    → skill/**/*.md        (render via jinja)
;   templates/skill/SKILL.md1        → skill/SKILL.md       (copy + janet post-processing)
;   extended-prelude/*.iml           → skill/extended-prelude/*.iml (copy)
;   knowledge-base/error_corpus/{error_corpus.json, error_corpus_schema.json} -> skill/error_corpus/

(alias
 (name default)
 (deps
  (alias skill)))

; Copies
; --------------------

; Copy .md and .iml files from templates/skill/ preserving directory structure.
; Note: SKILL.md is generated by SKILL.md1 with a separate rule

(rule
 (alias skill)
 (deps
  (glob_files_rec templates/skill/**.md)
  (glob_files_rec templates/skill/**.iml))
 (action
  (bash
   "src_skill=\"$(pwd | sed 's|_build/default/||')/skill\"; cd templates/skill && find . -type f \\( -name '*.md' -o -name '*.iml' \\) ! -name 'SKILL.md1' -not -path './error-fix-data/*' | while read -r f; do mkdir -p \"$src_skill/$(dirname \"$f\")\" && rm -f \"$src_skill/$f\" && cp \"$f\" \"$src_skill/$f\"; done")))

(subdir
 skill/error-fix-data
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (action
   (progn
    (copy ../../templates/skill/error-fix-data/README.md README.md)
    (copy
     ../../knowledge-base/error_corpus/error_corpus.json
     error_corpus.json)
    (copy
     ../../knowledge-base/error_corpus/error_corpus_schema.json
     error_corpus_schema.json)))))

(subdir
 skill/reference/prelude
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (action
   (copy
    ../../../templates/skill/reference/prelude/prelude.json
    prelude.json))))

; Jinja rendering
; --------------------
; Render .jinja templates with context.yaml, stripping the .jinja extension.
; e.g. templates/skill/reference/tactics.md.jinja → skill/reference/tactics.md
;
; Each directory with .jinja files needs its own (subdir ...) rule with explicit
; (targets ...) so that dune can track and promote the outputs correctly.
; When adding a new .jinja template, add a corresponding target entry here.

; skill/*.md.jinja

(subdir
 skill
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (deps
   (:tpl ../templates/skill/iml-syntax.md.jinja)
   (:ctx ../knowledge-base/context.yaml))
  (target iml-syntax.md)
  (action
   (bash "jinja -d %{ctx} -o %{target} %{tpl}"))))

; skill/reference/*.md.jinja

(subdir
 skill/reference
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (deps
   ../../templates/skill/reference/tactics.md.jinja
   ../../templates/skill/reference/all-prelude-module-signatures.md.jinja
   ../../knowledge-base/context.yaml)
  (targets tactics.md all-prelude-module-signatures.md)
  (action
   (bash
    "jinja -d ../../knowledge-base/context.yaml -o tactics.md ../../templates/skill/reference/tactics.md.jinja && jinja -d ../../knowledge-base/context.yaml -o all-prelude-module-signatures.md ../../templates/skill/reference/all-prelude-module-signatures.md.jinja"))))

; skill/reference/prelude/*.md.jinja

(subdir
 skill/reference/prelude
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (deps
   (glob_files ../../../templates/skill/reference/prelude/*.md.jinja)
   ../../../knowledge-base/context.yaml)
  (targets
   Int.md
   LChar.md
   LString.md
   List.md
   Map.md
   Multiset.md
   Option.md
   Real.md
   Result.md
   Set.md
   String.md
   top-level.md)
  (action
   (bash
    "for f in ../../../templates/skill/reference/prelude/*.md.jinja; do out=$(basename \"${f%.jinja}\"); jinja -d ../../../knowledge-base/context.yaml -o \"$out\" \"$f\"; done"))))

; SKILL.md
; --------------------

; Generate SKILL.md:
; echo SKILL.pt1
; echo tree structure of skill/ directory using skill-dir-tree.janet

(subdir
 skill
 (rule
  (alias skill)
  (mode
   (promote (until-clean)))
  (deps
   (glob_files_rec ../templates/skill/**.md)
   (glob_files_rec ../templates/skill/**.iml)
   (glob_files_rec ../templates/skill/**.jinja)
   (:skill-pt1 ../templates/skill/SKILL.pt1.md1)
   ../scripts/skill-dir-tree.janet)
  (target SKILL.md)
  (action
   (with-stdout-to
    SKILL.md
    (progn
     (cat %{skill-pt1})
     (echo "\n")
     (bash "janet ../scripts/skill-dir-tree.janet ../templates/skill")
     (echo
      "\nNote: there are some *.iml examples and *.json files as well that are not shown in the tree. Find them yourself if needed."))))))
