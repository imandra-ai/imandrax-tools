; Generate flat_named mirrors of ocaml_std_unavailable/<name>/ as
; ocaml_stdlib_unknown_id_<name>/ so consumers can read entries without
; walking the grouping dir. Mirror contents are copied (promoted).

; By default dune ignores dirs starting with `_`; opt the source group back in.
(dirs :standard _unknown_id_ocaml_stdlib)

(rule
 (mode promote)
 (target dune.flat_mirror.inc)
 (deps
  (:script _unknown_id_ocaml_stdlib/gen_dune_flat_mirror_inc.py)
  (source_tree _unknown_id_ocaml_stdlib))
 (action
  (with-stdout-to %{target} (run uv run --script %{script}))))

(include dune.flat_mirror.inc)
