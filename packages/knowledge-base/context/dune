(rule
 (targets context.yaml)
 (mode
  (promote (until-clean)))
 (deps
  (source_tree src)
  src/iml_caveats.yaml
  src/prelude.yaml
  src/quickstart_examples.yaml
  src/tactics.yaml
 )
 (action
  (with-stdout-to
   %{targets}
   (progn
    (echo "# DO NOT EDIT: Auto-generated from ./src/ via dump-of-fs\n")
    (run dump-of-fs src  --no-default-ignore --ignore dune --format yaml --yaml-multiline literal)
   )
   )))
