; ./src/
; ====================

(rule
  (alias context-src)
  (mode (promote (until-clean) (into src)))
  (action
    (copy# ../reference_prelude/prelude.yaml prelude.yaml)
  )
)

(rule
  (alias context-src)
  (mode (promote (until-clean) (into src)))
  (action
    (copy# ../reference_tactics/tactics.yaml tactics.yaml)
  )
)

; constants
(rule
  (alias context-src)
  (mode (promote (until-clean) (into src)))
  (action
    (progn
      (copy# ../constants/iml_caveats.yaml iml_caveats.yaml)
      (copy# ../constants/quickstart_examples.yaml quickstart_examples.yaml)
      (copy# ../constants/short_iml_101.yaml short_iml_101.yaml)
      (copy# ../constants/tactic_combinators.yaml tactic_combinators.yaml)
    )
  )
)

; ./context.yaml
; ====================

; sometimes this gave me "resolving root src: No such file or directory" error
; after a dune clean. doing a second dune build fixed it.
(rule
 (targets context.yaml)
 (alias default)
 (mode
  (promote (until-clean)))
 (deps
  (source_tree src)
  (alias context-src)
 )
 (action
  (with-stdout-to
   %{targets}
   (progn
    (echo "# DO NOT EDIT: Auto-generated from ./src/ via dump-of-fs\n")
    (run dump-of-fs src  --no-default-ignore --ignore dune --format yaml --yaml-multiline literal)
   )
   )))
